<h1>Přidat zvíře</h1>
<form action="/animals" method="POST">
 <input type="text" name="name" placeholder="Jméno" required>
 <br><br>
 <input type="text" name="species" placeholder="Druh" required>
 <br><br>
 <input type="number" name="age" placeholder="Věk" required>
