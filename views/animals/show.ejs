<h1><%= animal.name %></h1> 
<p>Druh: <%= animal.species %></p> 
<p>Věk: <%= animal.age %></p> 
<p><%= animal.description %></p> 

<% if (user) { %>
 <a href="/animals/<%= animal._id %>/edit">Upravit</a>
 <form action="/animals/<%= animal._id %>?_method=DELETE" method="POST">
 <button>Smazat</button>
 </form>
<% } %>

<p><a href="/animals">Zpět</a></p> 